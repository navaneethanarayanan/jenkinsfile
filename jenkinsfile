pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo 'Code checked out!'
            }
        }
        stage('Build') {
            steps {
                sh 'ls -la'
                sh 'echo Build done!'
            }
        }
        stage('Test') {
            steps {
                sh 'echo Tests passed!'
            }
        }
        stage('Deploy') {
            steps {
                sh 'echo Deployed!'
            }
        }
    }
    post {
        success { echo 'Success!' }
        failure { echo 'Failed!' }
    }
}
